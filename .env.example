OPENROUTER_API_KEY=your_openrouter_api_key_here
# Leave OPENROUTER_MODEL blank to use dynamic free-model routing:
# UI questions -> liquid/lfm-2.5-1.2b-instruct:free
# physics questions -> inclusionai/ring-2.6-1t:free
# general questions -> deepseek/deepseek-v4-flash:free
# Set OPENROUTER_MODEL only when you want to force one model first.
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_TIMEOUT=18
OPENROUTER_MAX_TOKENS=260
OPENROUTER_TEMPERATURE=0.20
